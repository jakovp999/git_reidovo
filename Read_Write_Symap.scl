FUNCTION_BLOCK "Read_Write_Symap"
VERSION : 0.1

VAR		
    Start_PIB : Int := 200;       // Начальный адрес PIB (Hardware)
    In_Bytes_Count : Int := 208;  // Кол-во байт входов In
    Start_PQB : Int := 200;       // Начальный адрес PQB (Hardware)
    Out_Bytes_Count : Int := 16;  // Кол-во байт выходов Out
    N_device : Int := 30;         // Кол-во Symap
    K_Filter : Real := 0.1;       // ИСПРАВЛЕНО: Добавлен отсутствующий коэффициент фильтрации
    History_Analog : Array[1..30, 1..41] of Real;
END_VAR

VAR_TEMP	
    i : Int;           // Индекс текущего устройства 1..30
    b : Int;           // Индекс байта для циклов 
    ch : Int;          // Индекс аналогового канала 1..41
    Current_PIB : Int; // Вычисленный физический адрес входов
    Current_PQB : Int; // Вычисленный физический адрес выходов	
    
    // --- НАЛОЖЕНИЕ В ПАМЯТИ (OVERLAY) ---
    In_Buffer_Bytes : Array[0..207] of Byte;
    In_Structure AT In_Buffer_Bytes : "UDT_Symap_In";
    In_Buffer_Words AT In_Buffer_Bytes : Array[1..104] of Word;
    
    Current_Raw_Real : Real;
END_VAR

BEGIN

// 1. ГЛАВНЫЙ ЦИКЛ ПО ВСЕМ УСТРОЙСТВАМ (от 1 до 30)
FOR #i := 1 TO #N_device DO // ИСПРАВЛЕНО: Добавлен префикс #
    
    // Расчет стартового адреса входов (%PIB) для текущего устройства
    #Current_PIB := #Start_PIB + ((#i - 1) * #In_Bytes_Count); // ИСПРАВЛЕНО: Добавлен префикс #
    
    // Побайтово собираем данные из периферии во временный массив
    FOR #b := 0 TO (#In_Bytes_Count - 1) DO
        // ИСПРАВЛЕНО: Вернули %PIB, так как адрес 200+ требует прямого периферийного доступа в S7-300
        #In_Buffer_Bytes[#b] := %IB(#Current_PIB + #b);
    END_FOR;
    
    // Копируем мгновенную сырую структуру целиком в глобальный DB
    "Read_write_Symap_Db".Devices[#i].In := #In_Structure;

    // 2. ВЛОЖЕННЫЙ ЦИКЛ УСРЕДНЕНИЯ АНАЛОГОВЫХ КАНАЛОВ (Должен быть ВНУТРИ цикла устройств)
    FOR #ch := 1 TO 41 DO
                
        // Читаем мгновенное значение из буфера (начиная с 14-го байта / 8-го слова)
        #Current_Raw_Real := INT_TO_REAL(WORD_TO_INT(#In_Buffer_Words[#ch + 7]));
        
        // Расчет экспоненциального сглаживания
        #History_Analog[#i, #ch] := #History_Analog[#i, #ch] + #K_Filter * (#Current_Raw_Real - #History_Analog[#i, #ch]);
        
        // Записываем усредненное значение в массив Filtered в DB
        "Read_write_Symap_Db".Devices[#i].Filtered[#ch] := INT_TO_WORD(REAL_TO_INT(#History_Analog[#i, #ch]));
        
    END_FOR; // Конец цикла по каналам #ch

END_FOR; // Конец главного цикла по устройствам #i

END_FUNCTION_BLOCK
